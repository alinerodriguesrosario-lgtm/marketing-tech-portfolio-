<script>
// ── SCROLL REVEAL ──
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ── EMAIL FLOWS ──
const flows = [
  { subject: 'Bem-vinda ao Femme', opens: 10886, clicks: 183 },
  { subject: 'Saiba mais sobre a Infertilidade feminina', opens: 6786, clicks: 188 },
  { subject: 'Conheça as características de uma menstruação saudável', opens: 5118, clicks: 64 },
  { subject: 'As DSTs estão crescendo — Previna-se', opens: 4307, clicks: 301 },
  { subject: 'Para onde vão os seus exames?', opens: 4086, clicks: 165 },
  { subject: 'O que você deve saber sobre a endometriose', opens: 3725, clicks: 175 },
];

const maxOpens = Math.max(...flows.map(f => f.opens));
const flowList = document.getElementById('flow-list');

flows.forEach(f => {
  const pct = (f.opens / maxOpens * 100).toFixed(1);
  flowList.innerHTML += `
    <div class="flow-row">
      <div class="flow-subject">${f.subject}</div>
      <div class="flow-opens">${f.opens.toLocaleString('pt-BR')}</div>
      <div class="flow-clicks">${f.clicks} cliques</div>
    </div>
    <div class="flow-bar-wrap">
      <div class="flow-bar-outer"><div class="flow-bar-inner" style="width:0%" data-w="${pct}%"></div></div>
    </div>`;
});

setTimeout(() => {
  document.querySelectorAll('.flow-bar-inner').forEach(b => {
    b.style.width = b.dataset.w;
  });
}, 600);

// ── HOUR CHART ──
const hourData = [
  {h:'00',v:5},{h:'01',v:2},{h:'02',v:1},{h:'03',v:1},{h:'04',v:2},{h:'05',v:4},
  {h:'06',v:10},{h:'07',v:28},{h:'08',v:72},{h:'09',v:95},{h:'10',v:88},{h:'11',v:78},
  {h:'12',v:60},{h:'13',v:65},{h:'14',v:70},{h:'15',v:62},{h:'16',v:55},{h:'17',v:58},
  {h:'18',v:80},{h:'19',v:55},{h:'20',v:42},{h:'21',v:30},{h:'22',v:20},{h:'23',v:12}
];

const hChart = document.getElementById('hourChart');
const maxH = Math.max(...hourData.map(d => d.v));

hourData.forEach(d => {
  const pct = (d.v / maxH * 100);
  const isHigh = pct > 80;
  const isMed = pct > 50 && !isHigh;
  hChart.innerHTML += `
    <div class="bar-col">
      <div class="bar-fill ${isHigh ? 'highlight' : isMed ? 'medium' : ''}" style="height:${pct}%"></div>
      <div class="bar-label ${isHigh ? 'highlight' : ''}">${d.h}h</div>
    </div>`;
});

// ── DAY CHART ──
const dayData = [
  {d:'Seg',v:100},{d:'Qui',v:55},{d:'Ter',v:42},{d:'Qua',v:35},{d:'Sex',v:25},{d:'Dom',v:10},{d:'Sáb',v:8}
];

const dChart = document.getElementById('dayChart');
const maxD = Math.max(...dayData.map(d => d.v));

dayData.forEach(d => {
  const pct = (d.v / maxD * 100);
  const isTop = pct === 100;
  const isMid = pct > 40 && !isTop;
  dChart.innerHTML += `
    <div class="day-col">
      <div class="day-fill ${isTop ? 'top' : isMid ? 'mid' : ''}" style="height:${pct}%"></div>
      <div class="day-label ${isTop ? 'top' : ''}">${d.d}</div>
    </div>`;
});

// ── SCROLL TO TOP ──
document.querySelector('.footer-right a').addEventListener('click', e => {
  e.preventDefault();
  window.scrollTo({ top: 0, behavior: 'smooth' });
});
</script>

